<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Thanh Toolbar chứa nút Back -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp"
        android:gravity="center_vertical"
        android:background="#FAFAFA">

        <ImageButton
            android:id="@+id/btnBackFromSinglePost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="Chi tiết bài viết"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- View trống dùng để đẩy icon Xóa sang bên phải -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnDeletePost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#FF0000"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Chúng ta tận dụng luôn RecyclerView kết hợp PostAdapter có sẵn để render 1 bài post -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSinglePost"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
